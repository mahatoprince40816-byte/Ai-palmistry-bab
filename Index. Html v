<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MysticPalm AI | Discover Your Destiny</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body {
            background: radial-gradient(circle at center, #1a1a2e 0%, #0f3460 100%);
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
        }
        .mystic-title { font-family: 'Cinzel', serif; }
        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .accent-glow {
            box-shadow: 0 0 20px rgba(233, 69, 96, 0.3);
        }
    </style>
</head>
<body class="flex flex-col items-center justify-center p-6 text-white">

    <header class="text-center mb-10">
        <h1 class="mystic-title text-4xl md:text-6xl font-bold text-[#e94560] drop-shadow-lg">MysticPalm AI</h1>
        <p class="text-gray-400 mt-2 tracking-widest uppercase text-sm">Ancient Wisdom Meets Modern Intelligence</p>
    </header>

    <main class="glass-card w-full max-w-md rounded-3xl p-8 accent-glow transition-all hover:scale-[1.01]">
        <div class="text-center">
            <div class="mb-6 inline-block p-4 rounded-full bg-[#e94560] bg-opacity-20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-[#e94560]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A10.003 10.003 0 003 20c3.905 0 7.352-2.43 8.774-5.88M11.35 9.235V19m0 0a8.99 8.99 0 004.546-1.977M11.35 9.235a3.5 3.5 0 11-4.09-3.491m4.941 2.536a3.5 3.5 0 113.154-3.154m-4.941 3.154a3.501 3.501 0 001.611 2.483" />
                </svg>
            </div>
            <h2 class="text-2xl font-semibold mb-2">Reveal Your Future</h2>
            <p class="text-gray-400 text-sm mb-8">Upload a clear photo of your right palm. Ensure the lines are visible under bright light.</p>
        </div>

        <div class="space-y-4">
            <div class="relative group">
                <input type="file" id="palmImage" accept="image/*" class="hidden">
                <label for="palmImage" class="flex items-center justify-center w-full py-4 px-6 border-2 border-dashed border-gray-600 rounded-xl cursor-pointer group-hover:border-[#e94560] transition-colors">
                    <span class="text-gray-300">Choose Image...</span>
                </label>
            </div>

            <button onclick="startReading()" class="w-full bg-[#e94560] hover:bg-[#ff5d78] text-white font-bold py-4 rounded-xl shadow-lg transform active:scale-95 transition-all">
                READ MY DESTINY
            </button>
        </div>

        <div id="result" class="mt-8 hidden animate-fade-in">
            <div class="h-px bg-gray-700 w-full mb-6"></div>
            <div class="bg-black bg-opacity-30 p-4 rounded-xl border border-gray-800">
                <p id="predictionText" class="text-gray-200 leading-relaxed italic"></p>
            </div>
        </div>
    </main>

    <footer class="mt-12 text-gray-500 text-[10px] uppercase tracking-widest text-center">
        &copy; 2026 MysticPalm AI <br>
        <span class="opacity-50 text-white">For Entertainment Purposes Only</span>
    </footer>

    <script>
        async function startReading() {
            const fileInput = document.getElementById('palmImage');
            const resultDiv = document.getElementById('result');
            const predictionText = document.getElementById('predictionText');

            if (fileInput.files.length === 0) {
                alert("Please select a palm photo first!");
                return;
            }

            resultDiv.classList.remove('hidden');
            predictionText.innerHTML = "✨ The AI is tracing your lines of fate...";

            const file = fileInput.files[0];
            const reader = new FileReader();

            reader.onloadend = async () => {
                const base64Data = reader.result.split(',')[1];
                
                // IMPORTANT: We use a relative path here so Netlify Functions handle the API key
                try {
                    const response = await fetch('/.netlify/functions/get-prediction', {
                        method: 'POST',
                        body: JSON.stringify({ image: base64Data })
                    });
                    const data = await response.json();
                    predictionText.innerHTML = data.prediction;
                } catch (error) {
                    predictionText.innerHTML = "The cosmos are busy. Please try again in a moment.";
                }
            };
            reader.readAsDataURL(file);
        }
    </script>
</body>
</html>
